# =============================================================================
# COMPLAINT SERVICE — copy this file to:  complaint-management-system\.env
# (project ROOT — same folder as this package.json)
# =============================================================================
# Do NOT put SES_FROM_EMAIL or ADMIN_EMAIL here.
# Email settings go in: services\notification-service\.env
# Full steps: docs\LOCAL_RUN.md
# =============================================================================

PORT=5000
NODE_ENV=development
AWS_REGION=ap-south-1
DYNAMODB_TABLE=Complaints
S3_BUCKET_NAME=your-bucket-name

# Notification microservice URL (Terminal 1 must be running on port 5001 first)
NOTIFICATION_SERVICE_URL=http://localhost:5001
