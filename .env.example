# =============================================================================
# COMPLAINT SERVICE — copy to: complaint-management-system\.env (project ROOT)
# =============================================================================
# Docker Compose: uses "aws configure" files from %USERPROFILE%\.aws (auto-mounted).
# Optional override (only if mount does not work — do NOT commit real keys):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# =============================================================================

PORT=5000
NODE_ENV=development
AWS_REGION=ap-south-1
DYNAMODB_TABLE=Complaints
S3_BUCKET_NAME=your-bucket-name

# Notification microservice URL (Terminal 1 must be running on port 5001 first)
NOTIFICATION_SERVICE_URL=http://localhost:5001

# Phase 16 — optional locally (EKS enables in deployment YAML)
# STRUCTURED_LOGS=true
# ENABLE_XRAY=true
# AWS_XRAY_TRACING_NAME=complaint-service
