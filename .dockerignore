# Dependencies (reinstalled inside the image)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment and secrets (inject at runtime via -e / orchestrator)
.env
.env.*
!.env.example

# Git and editor
.git/
.gitignore
.github/
.vscode/
.idea/
*.swp
*.swo

# Documentation and local tooling (not needed in runtime image)
README.md
docs/
*.md
!package.json

# Tests and coverage
coverage/
.nyc_output/
**/__tests__/
**/*.test.js
**/*.spec.js

# OS artifacts
.DS_Store
Thumbs.db

# Docker (avoid recursive context)
Dockerfile*
docker-compose*.yml
.dockerignore

# Misc
dist/
build/
*.log
terminals/
