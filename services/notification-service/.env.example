PORT=5001
NODE_ENV=development
AWS_REGION=ap-south-1

SES_FROM_EMAIL=yaswanthkumarpulapa@gmail.com
ADMIN_EMAIL=yaswanthkumarpulapa@gmail.com

# AWS Secrets Manager (optional — EKS uses secret; local uses .env by default)
# NOTIFICATION_SECRET_NAME=complaint-management/notification
# USE_SECRETS_MANAGER=false
# Optional SNS topic (leave empty to skip SNS)
# SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:complaint-alerts
